# =============================================================
# Winaity Extractor - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# Database
DATABASE_URL=postgresql+asyncpg://winaity:changeme@localhost:55432/winaity
DB_PASSWORD=changeme
POSTGRES_PORT=55432

# Redis
REDIS_URL=redis://localhost:16379/0
REDIS_PORT=16379

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACTIVE_KID=v1
JWT_PREVIOUS_SECRET_KEY=
JWT_PREVIOUS_KID=v0
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_WINDOW_SECONDS=60
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_REFRESH_RATE_LIMIT=30
AUTH_REFRESH_WINDOW_SECONDS=60
AUTH_COOKIE_MODE=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_CSRF_COOKIE_NAME=csrf_token
AUTH_CSRF_HEADER_NAME=X-CSRF-Token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3 (for exports)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=winaity-exports
AWS_REGION=eu-west-3

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend
BACKEND_PORT=18000
FRONTEND_PORT=15173
NEXT_PUBLIC_API_URL=http://localhost:18000/api/v1
NEXT_PUBLIC_AUTH_COOKIE_MODE=false
NEXT_PUBLIC_AUTH_CSRF_COOKIE_NAME=csrf_token
NEXT_PUBLIC_AUTH_CSRF_HEADER_NAME=X-CSRF-Token
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:15173
CHECKOUT_ALLOWED_ORIGINS=http://localhost:15173

# Winaity Call Center Integration
WINAITY_CALLCENTER_WEBHOOK_URL=
WINAITY_CALLCENTER_API_KEY=

# App
APP_NAME=Winaity Extractor
APP_ENV=development
DEBUG=true
CONSENT_ENFORCEMENT_ENABLED=false
B2C_MODE_ENABLED=true
B2C_WEBHOOK_SECRET=change-me-webhook-secret
META_WEBHOOK_VERIFY_TOKEN=change-me-meta-verify-token
META_ACCESS_TOKEN=
